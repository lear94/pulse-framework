# Copia a `.env` para correr la wiki sin Docker (requiere Postgres accesible y
# openssl/pkg-config en el host). Con `./run.sh` NO hace falta: las vars se pasan
# por entorno al contenedor.

DATABASE_URL=postgres://wiki:wiki@127.0.0.1:5440/wiki
# REDIS_URL=redis://127.0.0.1:6379          # opcional: activa caché L2 + orquestador
JWT_SECRET=pulse-wiki-demo-secret-key-change-me-please   # >=16 chars; cámbialo en serio
PULSE_ADMIN_USERS=admin
PULSE_RATE_LIMIT_MAX=1000
RUST_LOG=info
